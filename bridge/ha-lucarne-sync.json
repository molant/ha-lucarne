{
  "_comment": "Human-readable representation of the ha-lucarne-sync macOS Shortcut. The binary .shortcut file is created by the user in Shortcuts.app on the Mac mini (user-action step in Sub-Phase C). This JSON documents the logical structure for review and reconstruction.",
  "name": "ha-lucarne-sync",
  "actions": [
    {
      "step": 1,
      "description": "Retrieve webhook secret from macOS Keychain",
      "action": "Run Shell Script",
      "script": "security find-generic-password -a 'ha-lucarne' -s 'ha-lucarne-webhook-secret' -w",
      "output": "WEBHOOK_SECRET"
    },
    {
      "step": 2,
      "description": "Get Family Reminders (filter: items assigned to Ingrid or all, depending on assignee-filter availability)",
      "action": "Get Reminders",
      "list": "Family",
      "filter": "assignee is Ingrid (fallback: all items if assignee filter unavailable)",
      "output": "family_reminders"
    },
    {
      "step": 3,
      "description": "Build Family items list",
      "action": "Repeat with Each (family_reminders)",
      "per_item": {
        "id": "Reminder.identifier",
        "title": "Reminder.title",
        "due": "Reminder.dueDate (ISO 8601 UTC, or null)",
        "completed": "Reminder.isCompleted",
        "notes": "Reminder.notes (optional)"
      },
      "output": "family_items"
    },
    {
      "step": 4,
      "description": "Get Groceries Reminders (all items, no filter)",
      "action": "Get Reminders",
      "list": "Groceries",
      "filter": "all",
      "output": "groceries_reminders"
    },
    {
      "step": 5,
      "description": "Build Groceries items list",
      "action": "Repeat with Each (groceries_reminders)",
      "per_item": {
        "id": "Reminder.identifier",
        "title": "Reminder.title",
        "due": "Reminder.dueDate (ISO 8601 UTC, or null)",
        "completed": "Reminder.isCompleted",
        "notes": "Reminder.notes (optional)"
      },
      "output": "groceries_items"
    },
    {
      "step": 6,
      "description": "Build webhook payload JSON",
      "action": "Make Dictionary",
      "value": {
        "lists": [
          {
            "apple_list_name": "Family",
            "filter_applied": "assigned_to_ingrid",
            "items": "family_items"
          },
          {
            "apple_list_name": "Groceries",
            "filter_applied": "all",
            "items": "groceries_items"
          }
        ]
      },
      "output": "payload"
    },
    {
      "step": 7,
      "description": "POST payload to HA webhook",
      "action": "Get Contents of URL",
      "url": "http://homeassistant.local:8123/api/webhook/[WEBHOOK_SECRET]",
      "method": "POST",
      "headers": { "Content-Type": "application/json" },
      "body": "payload (JSON encoded)",
      "output": "response"
    },
    {
      "step": 8,
      "description": "Log failure if non-200 (successful runs are silent — absence of error lines in the log means success)",
      "action": "If (URL response status != 200)",
      "then": "Log notification: 'ha-lucarne-sync failed: HTTP [status]'",
      "note": "Successful 200 responses are not logged. To confirm the bridge is working, check HA automation traces or the todo entity's last_changed timestamp."
    }
  ]
}
