# Copy this file to .env and fill in your values.
# .env is gitignored — safe for host/path/id that shouldn't be public.

# SSH target for your Home Assistant host (uses ~/.ssh/config aliases if defined).
HA_SSH_HOST=your-ha-host

# Absolute remote path for the custom integration (used by deploy-integration.sh).
# The cards ship inside the integration (frontend/ha-lucarne.js) and are
# auto-registered on setup, so this is the only deploy target.
# Must end in /custom_components/lucarne_family — the deploy script refuses any
# other path to keep rsync --delete safe.
HA_INTEGRATION_PATH=/homeassistant/custom_components/lucarne_family
